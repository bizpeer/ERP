# Example Environment Configuration
# Copy this to .env and fill in your values for local development

# ─── Server Config ────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_PASSWORD=erp_secret
DATABASE_URL=postgresql://erp_user:erp_secret@postgres:5432/erp_main

# ─── Cache (Redis) ────────────────────────────────────────────
REDIS_PASSWORD=erp_secret
REDIS_URL=redis://:erp_secret@redis:6379

# ─── Message Bus (RabbitMQ) ───────────────────────────────────
RABBITMQ_USER=erp_user
RABBITMQ_PASSWORD=erp_secret
RABBITMQ_URL=amqp://erp_user:erp_secret@rabbitmq:5672

# ─── Audit Logs (MongoDB) ────────────────────────────────────
MONGO_PASSWORD=erp_secret
MONGODB_URL=mongodb://erp_user:erp_secret@mongodb:27017/erp_logs

# ─── Object Storage (MinIO) ───────────────────────────────────
MINIO_USER=erp_admin
MINIO_PASSWORD=erp_secret

# ─── JWT Secrets ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=super_secret_jwt_key
JWT_REFRESH_SECRET=super_secret_refresh_key

# ─── API Gateway ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000

# ─── External Services ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_mock
